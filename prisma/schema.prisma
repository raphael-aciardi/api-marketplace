generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  username      String?        @unique
  cpfCnpj       String         @unique
  password      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  sellerProfile SellerProfile?
  givenReviews  Review[]       @relation("BuyerReviews")
  receivedReviews Review[]     @relation("SellerReviews")
  cartItems     Cart[]
}

model SellerProfile {
  id             Int      @id @default(autoincrement())
  bankDetails    String
  billingAddress String
  userId         Int      @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String?
  sellerId  Int
  seller    User     @relation("SellerReviews", fields: [sellerId], references: [id], onDelete: Cascade)
  buyerId   Int
  buyer     User     @relation("BuyerReviews", fields: [buyerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Product {
  id          Int          @id @default(autoincrement()) @map("id_produto")
  name        String
  description String
  price       Float
  image       String?
  tags        ProductTag[]
  salesQuantity Int        @default(0)
  cartItems   Cart[]
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Tag {
  id          Int          @id @default(autoincrement()) @map("id_tag")
  description String
  products    ProductTag[]
}

model ProductTag {
  id        Int @id @default(autoincrement()) @map("id_product_tag")
  productId Int @map("id_produto")
  tagId     Int @map("id_tag")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([productId, tagId])
}

model Cart {
  id        Int      @id @default(autoincrement()) @map("id_carrinho")
  productId Int      @map("id_produto")
  userId    Int      @map("id_usuario")
  quantity  Int      @default(1)
  
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
}

